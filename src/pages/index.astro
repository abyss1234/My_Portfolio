---
import "../styles/global.css";
import { contactForm, education, experiences, profile, projects, skills } from "../data/portfolio";

const navItems = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Ng Boon Bin is a fresh Computer Science graduate building practical applications and seeking junior developer opportunities."
    />
    <title>{profile.name} | Personal Portfolio</title>
  </head>
  <body class="bg-[#f7f4ef]">
    <header class="sticky top-0 z-50 border-b border-[#dfd8ce] bg-[#f7f4ef]/88 backdrop-blur-xl">
      <nav class="section-shell flex h-16 items-center justify-between text-sm text-[#1f2933]">
        <a href="#top" class="flex items-center gap-3 font-semibold">
          <span class="grid size-9 place-items-center rounded-full bg-[#111827] text-white">NB</span>
          <span class="hidden sm:inline">{profile.name}</span>
        </a>

        <div class="hidden items-center gap-6 md:flex">
          {navItems.map((item) => <a class="nav-link" href={item.href}>{item.label}</a>)}
        </div>

        <a class="button button-dark" href={profile.resume} download>Resume</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero-section">
        <div class="section-shell grid min-h-[calc(100svh-64px)] gap-12 py-16 md:grid-cols-[1.05fr_0.95fr] md:items-center lg:py-20">
          <div class="fade-up">
            <p class="hero-kicker">Hello!</p>
            <h1 class="mt-5 max-w-4xl text-5xl font-semibold leading-[1.03] tracking-normal text-[#111827] md:text-7xl">
              I am <span class="text-[#2755d8]">{profile.name}</span>
            </h1>
            <p class="mt-5 font-mono text-xl text-[#4b5563] md:text-2xl">{profile.role}</p>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-[#536172]">
              {profile.headline} {profile.summary}
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a class="button button-dark" href="#contact">CONTECT ME</a>
              <a class="button button-light" href={profile.resume} download>Resume</a>
            </div>

            <div class="mt-10 flex items-center gap-5">
              <a class="icon-link" href={`mailto:${profile.email}`} aria-label="Email Ng Boon Bin">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
              </a>
              <a class="icon-link" href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn profile">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 10.5V18"/><path d="M6.5 6.5v.1"/><path d="M10.5 18v-7.5"/><path d="M10.5 14c0-2.2 1.3-3.5 3.2-3.5S17 11.8 17 14v4"/><path d="M4 3h16a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/></svg>
              </a>
              <a class="icon-link" href={profile.github} target="_blank" rel="noreferrer" aria-label="GitHub profile">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.5c-5.2 0-9.5 4.2-9.5 9.4 0 4.2 2.7 7.7 6.5 9 .5.1.7-.2.7-.5v-1.8c-2.7.6-3.2-1.1-3.2-1.1-.4-1-.9-1.3-.9-1.3-.8-.5.1-.5.1-.5.8.1 1.3.9 1.3.9.8 1.3 2 1 2.5.8.1-.6.3-1 .5-1.2-2.1-.2-4.3-1-4.3-4.6 0-1 .4-1.9.9-2.5-.1-.2-.4-1.2.1-2.5 0 0 .8-.2 2.6 1a8.7 8.7 0 0 1 4.7 0c1.8-1.2 2.6-1 2.6-1 .5 1.3.2 2.3.1 2.5.6.6.9 1.5.9 2.5 0 3.6-2.2 4.4-4.3 4.6.3.3.6.9.6 1.7v2.5c0 .3.2.6.7.5 3.8-1.3 6.5-4.8 6.5-9 0-5.2-4.3-9.4-9.5-9.4Z"/></svg>
              </a>
              <a class="icon-link" href={profile.resume} download aria-label="Download resume">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h4"/><path d="M9.5 13h5"/><path d="M9.5 16h5"/></svg>
              </a>
            </div>
          </div>

          <aside class="fade-up delay-1">
            <div class="hero-portrait" aria-label="Portrait artwork">
              <img src={profile.avatar} alt="Portrait of Ng Boon Bin" />
            </div>
          </aside>
        </div>
      </section>

      <section id="about" class="bg-white py-24">
        <div class="section-shell grid gap-12 lg:grid-cols-[0.78fr_1.22fr]">
          <div>
            <p class="eyebrow">About Me</p>
            <h2 class="section-title mt-4">A fresh graduate with real project momentum.</h2>
          </div>
          <div class="space-y-6 text-lg leading-8 text-[#536172]">
            <p>
              I enjoy turning learning into working software. My strongest progress has come from
              building real projects, solving the next problem in front of me, and improving each part
              until the application feels more useful and reliable.
            </p>
            <p>
              I am honest about being entry-level, but I am serious about growing. I bring consistency,
              curiosity, and a hardworking attitude, and I am looking for a team where I can learn from
              experienced developers while contributing with care.
            </p>
          </div>
        </div>
      </section>

      <section id="experience" class="bg-[#111827] py-24 text-white">
        <div class="section-shell">
          <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div class="max-w-2xl">
              <p class="eyebrow text-[#8ee0d4]">Experience</p>
              <h2 class="mt-4 text-4xl font-semibold tracking-normal md:text-5xl">Internship experience.</h2>
            </div>
            <p class="max-w-md leading-7 text-slate-300">
              These are the working experiences from my resume, focused on applied AI, automation,
              backend services, and practical software delivery.
            </p>
          </div>

          <div class="mt-14 grid gap-5">
            {
              experiences.map((item) => (
                <article class="experience-item">
                  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#8ee0d4]">{item.period}</p>
                      <h3 class="mt-2 text-2xl font-semibold">{item.title}</h3>
                      <p class="mt-1 text-slate-300">{item.organization}</p>
                    </div>
                  </div>
                  <p class="mt-5 max-w-3xl leading-7 text-slate-300">{item.description}</p>
                  <ul class="mt-5 grid list-disc gap-3 pl-5 text-slate-300">
                    {item.highlights.map((highlight) => <li class="leading-7">{highlight}</li>)}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="skills" class="bg-[#f7f4ef] py-24">
        <div class="section-shell">
          <div class="max-w-2xl">
            <p class="eyebrow">Skills</p>
            <h2 class="section-title mt-4">Technical foundation I can keep building on.</h2>
          </div>
          <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {
              skills.map((group) => (
                <article class="soft-card">
                  <h3 class="text-lg font-semibold text-[#111827]">{group.category}</h3>
                  <div class="mt-5 flex flex-wrap gap-2">
                    {group.items.map((item) => <span class="skill-pill">{item}</span>)}
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="projects" class="bg-white py-24">
        <div class="section-shell">
          <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div class="max-w-2xl">
              <p class="eyebrow">Featured Project</p>
              <h2 class="section-title mt-4">One project, shown as a complete case study.</h2>
            </div>
            <p class="max-w-md leading-7 text-[#5f6b7a]">
              The project area is data-driven, so future projects can be added without redesigning this
              page.
            </p>
          </div>

          <div class="mt-12 grid gap-8">
            {
              projects.map((project) => (
                <article class="project-case">
                  <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
                    <div>
                      <p class="eyebrow">{project.type}</p>
                      <h3 class="mt-4 text-4xl font-semibold tracking-normal text-[#111827]">{project.name}</h3>
                      <p class="mt-5 text-lg leading-8 text-[#536172]">{project.description}</p>
                      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                        <a class="button button-dark" href={project.demoUrl} target="_blank" rel="noreferrer">Live Demo</a>
                        <a class="button button-light" href={project.githubUrl} target="_blank" rel="noreferrer">
                          GitHub
                        </a>
                      </div>
                    </div>

                    <div class="grid gap-5">
                      <div class="case-block">
                        <h4>Problem solved</h4>
                        <p>{project.problem}</p>
                      </div>
                      <div class="case-block">
                        <h4>My role</h4>
                        <p>{project.role}</p>
                      </div>
                    </div>
                  </div>

                  <div class="mt-10 grid gap-4 md:grid-cols-2">
                    {project.screenshots.map((screenshot) => (
                      <figure class="project-shot">
                        <img src={screenshot.src} alt={screenshot.alt} loading="lazy" />
                        <figcaption>{screenshot.label}</figcaption>
                      </figure>
                    ))}
                  </div>

                  <div class="mt-10 grid gap-5 lg:grid-cols-3">
                    <div class="case-block">
                      <h4>Key features</h4>
                      <ul class="mt-4 grid list-disc gap-2 pl-5">
                        {project.features.map((feature) => <li>{feature}</li>)}
                      </ul>
                    </div>
                    <div class="case-block">
                      <h4>Technologies</h4>
                      <div class="mt-4 flex flex-wrap gap-2">
                        {project.technologies.map((tech) => <span class="skill-pill">{tech}</span>)}
                      </div>
                    </div>
                    <div class="case-block">
                      <h4>What I learned</h4>
                      <ul class="mt-4 grid list-disc gap-2 pl-5">
                        {project.learned.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="education" class="border-y border-[#dfd8ce] bg-[#f7f4ef] py-20">
        <div class="section-shell grid gap-8 md:grid-cols-[0.75fr_1.25fr] md:items-center">
          <div>
            <p class="eyebrow">Education</p>
            <h2 class="section-title mt-4">Academic background.</h2>
          </div>
          <div class="soft-card">
            <p class="text-2xl font-semibold text-[#111827]">{education.degree}</p>
            <p class="mt-3 text-lg text-[#536172]">{education.school}</p>
            <p class="mt-2 font-semibold text-[#0f766e]">CGPA: {education.cgpa}</p>
            <p class="mt-2 font-semibold text-[#0f766e]">Graduation Year: {education.graduation}</p>
          </div>
        </div>
      </section>

      <section id="contact" class="bg-white py-24">
        <div class="section-shell grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <p class="eyebrow">Contact</p>
            <h2 class="section-title mt-4">Let us talk about opportunities.</h2>
            <p class="mt-5 text-lg leading-8 text-[#536172]">
              I am available for junior developer roles, graduate programs, internships, and freelance
              opportunities where I can learn quickly and contribute carefully.
            </p>
            <div class="mt-8 flex items-center gap-5">
              <a class="icon-link" href={`mailto:${profile.email}`} aria-label="Email Ng Boon Bin">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
              </a>
              <a class="icon-link" href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn profile">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 10.5V18"/><path d="M6.5 6.5v.1"/><path d="M10.5 18v-7.5"/><path d="M10.5 14c0-2.2 1.3-3.5 3.2-3.5S17 11.8 17 14v4"/><path d="M4 3h16a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/></svg>
              </a>
              <a class="icon-link" href={profile.github} target="_blank" rel="noreferrer" aria-label="GitHub profile">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.5c-5.2 0-9.5 4.2-9.5 9.4 0 4.2 2.7 7.7 6.5 9 .5.1.7-.2.7-.5v-1.8c-2.7.6-3.2-1.1-3.2-1.1-.4-1-.9-1.3-.9-1.3-.8-.5.1-.5.1-.5.8.1 1.3.9 1.3.9.8 1.3 2 1 2.5.8.1-.6.3-1 .5-1.2-2.1-.2-4.3-1-4.3-4.6 0-1 .4-1.9.9-2.5-.1-.2-.4-1.2.1-2.5 0 0 .8-.2 2.6 1a8.7 8.7 0 0 1 4.7 0c1.8-1.2 2.6-1 2.6-1 .5 1.3.2 2.3.1 2.5.6.6.9 1.5.9 2.5 0 3.6-2.2 4.4-4.3 4.6.3.3.6.9.6 1.7v2.5c0 .3.2.6.7.5 3.8-1.3 6.5-4.8 6.5-9 0-5.2-4.3-9.4-9.5-9.4Z"/></svg>
              </a>
              <a class="icon-link" href={profile.resume} download aria-label="Download resume">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h4"/><path d="M9.5 13h5"/><path d="M9.5 16h5"/></svg>
              </a>
            </div>
            <p class="mt-6 font-medium text-[#334155]">{profile.email} &middot; {profile.location}</p>
            <a class="button button-dark mt-8 inline-flex" href={profile.resume} download>Download Resume</a>
          </div>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="post"
            class="soft-card"
          >
            <input type="hidden" name="access_key" value={contactForm.web3FormsAccessKey} />
            <input type="hidden" name="subject" value={contactForm.subject} />
            <input type="hidden" name="from_name" value={`${profile.name} Portfolio`} />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
            <div class="grid gap-5">
              <label class="form-label">
                Name
                <input name="name" type="text" required class="form-field" />
              </label>
              <label class="form-label">
                Email
                <input name="email" type="email" required class="form-field" />
              </label>
              <label class="form-label">
                Message
                <textarea name="message" rows="6" required class="form-field py-3"></textarea>
              </label>
              <button type="submit" class="button button-dark">Send Message</button>
              <p id="contact-result" class="form-status" role="status" aria-live="polite">
                Feel free to reach out to me! 
              </p>
            </div>
          </form>
        </div>
      </section>
    </main>

    <footer class="bg-[#111827] py-8 text-white">
      <div class="section-shell flex flex-col gap-3 text-sm text-slate-300 md:flex-row md:items-center md:justify-between">
        <p><span class="font-semibold text-white">{profile.name}</span> &middot; Fresh Graduate Developer</p>
        <p>&copy; 2026 {profile.name}. All rights reserved.</p>
      </div>
    </footer>
    <script>
      const form = document.getElementById("contact-form");
      const result = document.getElementById("contact-result");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!(form instanceof HTMLFormElement) || !result) {
          return;
        }

        const formData = new FormData(form);
        const accessKey = String(formData.get("access_key") || "");
        if (!accessKey || accessKey === "YOUR_WEB3FORMS_ACCESS_KEY") {
          result.textContent = "Contact form is not configured yet. Please add the Web3Forms access key.";
          result.dataset.state = "error";
          return;
        }

        result.textContent = "Sending message...";
        result.dataset.state = "loading";

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              Accept: "application/json",
            },
            body: formData,
          });
          const data = await response.json();

          if (response.ok && data.success) {
            result.textContent = "Message sent. Thank you for reaching out.";
            result.dataset.state = "success";
            form.reset();
            return;
          }

          result.textContent = data.message || "Message could not be sent. Please try again later.";
          result.dataset.state = "error";
        } catch {
          result.textContent = "Message could not be sent. Please email me directly instead.";
          result.dataset.state = "error";
        }
      });
    </script>
  </body>
</html>
